{
  "name": "Chronicles",
  "version": "1.0.0",
  "main": "main.bundle.mjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "./build.sh",
    "lint": "bash scripts/lint.sh --fix",
    "lint:check": "bash scripts/lint.sh",
    "postinstall": "yarn run electron-rebuild",
    "prebuild": "yarn run lint:check && node ./scripts/icons.js",
    "start": "node ./scripts/dev.mjs",
    "test": "vitest run && npm rebuild better-sqlite3 --build-from-source 2>/dev/null && node --import tsx --test 'src/node-client/*.test.ts'",
    "test:watch": "vitest",
    "test:node-client": "node --import tsx --test 'src/node-client/*.test.ts'",
    "test:rebuild": "npm rebuild better-sqlite3 --build-from-source 2>/dev/null; vitest run && node --import tsx --test 'src/node-client/*.test.ts'; yarn run electron-rebuild 2>/dev/null"
  },
